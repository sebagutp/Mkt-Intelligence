# MIH Client Configuration Template
# Copy this file to provisioning/clients/<client-name>.env and fill in values

# Client info
CLIENT_NAME=
CLIENT_DOMAIN=
CLIENT_EMAIL=

# Supabase
SUPABASE_PROJECT_REF=
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# BigQuery
BQ_PROJECT_ID=
BQ_DATASET=mih_${CLIENT_NAME}
BQ_SERVICE_ACCOUNT_JSON=

# OAuth (Google)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_ADS_DEV_TOKEN=

# Meta
META_APP_ID=
META_APP_SECRET=

# Branding
BRAND_PRIMARY_COLOR=#2563eb
BRAND_ACCENT_COLOR=#f59e0b
BRAND_LOGO_URL=

# =============================================================================
# MIH Client Configuration Template
# Copy to provisioning/clients/<client-slug>.env and fill in all values.
# Usage: ./provisioning/provision.sh provisioning/clients/<client-slug>.env
# =============================================================================

# ── Client Info ──────────────────────────────────────────────────────────────
CLIENT_NAME="Acme Corp"
CLIENT_SLUG="acme"
CLIENT_EMAIL="admin@acme.com"
CLIENT_TIMEZONE="America/Santiago"
PLAN="starter"                          # starter | professional | enterprise
MONTHLY_BUDGET=5000

# ── Google Cloud / BigQuery ──────────────────────────────────────────────────
GCP_PROJECT_ID=""
BQ_DATASET="mih_${CLIENT_SLUG}"        # Convention: mih_<slug>
BQ_LOCATION="US"
BQ_SERVICE_ACCOUNT_KEY_FILE=""          # Path to .json key file

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_PROJECT_REF=""
SUPABASE_URL="https://xxx.supabase.co"
SUPABASE_DB_URL="postgresql://postgres:password@db.xxx.supabase.co:5432/postgres"
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# ── Google OAuth (for Google Ads + GA4) ──────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
GOOGLE_ADS_DEV_TOKEN=""

# ── Channel Toggles ─────────────────────────────────────────────────────────
ENABLE_GA4=true
ENABLE_GOOGLE_ADS=true
ENABLE_META_ADS=true
ENABLE_EMAIL=false
ENABLE_LINKEDIN=false

# ── GA4 ──────────────────────────────────────────────────────────────────────
GA4_PROPERTY_ID=""

# ── Google Ads ───────────────────────────────────────────────────────────────
GOOGLE_ADS_CUSTOMER_ID=""               # Format: 123-456-7890 (no dashes stored)

# ── Meta Ads ─────────────────────────────────────────────────────────────────
META_APP_ID=""
META_APP_SECRET=""
META_AD_ACCOUNT_ID=""                   # Format: act_123456789

# ── Email Marketing ──────────────────────────────────────────────────────────
EMAIL_PROVIDER=""                       # mailchimp | brevo | webhook
EMAIL_API_KEY=""

# ── LinkedIn ─────────────────────────────────────────────────────────────────
LINKEDIN_ORGANIZATION_ID=""

# ── Branding ─────────────────────────────────────────────────────────────────
BRAND_PRIMARY_COLOR="#2563eb"
BRAND_ACCENT_COLOR="#f59e0b"
BRAND_LOGO_URL=""
BRAND_COMPANY_NAME="${CLIENT_NAME}"
BRAND_SUPPORT_EMAIL="${CLIENT_EMAIL}"

# ── Frontend Deploy ──────────────────────────────────────────────────────────
FRONTEND_DOMAIN=""                      # e.g., analytics.acme.com
FRONTEND_PLATFORM="vercel"              # vercel | cloudflare
